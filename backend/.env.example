APP_NAME=AutoTrip API
ENVIRONMENT=local
DEBUG=True
LOG_LEVEL=INFO

NOTION_API_KEY=ntn_your_secret_key_here
NOTION_DATABASE_ID=your_database_id_here

SCRAPER_BASE_URL=https://www.jr-odekake.net/railroad/eki/

SQLITE_CACHE_PATH=autotrip_cache.db
